input_shape = (32, 32)

    @pytest.mark.parametrize("input_shape", [(32, 32)])#, (64, 64), (128, 128), (256, 256)])
    def test_linear(input_shape):
        class Basic(nn.Module):
            def __init__(self):
                super().__init__()
                input_size = input_shape[0]
                self.linear_a = nn.Linear(input_size, 2 * input_size, bias=False)
                self.linear_b = nn.Linear(2 * input_size, 2 * input_size, bias=False)

                # linear weights are typically initialized to have mean 0 and std 0.1
                self.mm_c_weight = torch.nn.Parameter(torch.randn(2 * input_size, 8 * input_size) * 0.1)
                self.mm_d_weight = torch.nn.Parameter(torch.randn(8 * input_size, 8 * input_size) * 0.1)

            def forward(self, x):
                x = self.linear_a(x)
                x = self.linear_b(x)
                x = self.linear_b(x)
                x = torch.mm(x, self.mm_c_weight)
                x = torch.mm(x, self.mm_d_weight)
                x = torch.mm(x, self.mm_d_weight)
                return x

        cc = CompilerConfig()
        cc.enable_consteval = True
        cc.consteval_parameters = True
>       verify_module(
